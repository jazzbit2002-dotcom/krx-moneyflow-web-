{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "us_macro_brief_v1_1",
  "title": "F29 US Macro Daily Brief (v1.1 — server v7 contract)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "as_of",
    "headline",
    "deck",
    "key_points",
    "sections",
    "watchpoints",
    "social_summary",
    "email_subject",
    "email_preview",
    "disclaimer"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "us_macro_brief_v1"
    },
    "as_of": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "headline": {
      "type": "string",
      "minLength": 12,
      "maxLength": 60
    },
    "deck": {
      "type": "string",
      "minLength": 30,
      "maxLength": 160
    },
    "key_points": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 12,
        "maxLength": 120
      }
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "body",
          "tickers",
          "themes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "conclusion",
              "breadth",
              "size_style",
              "rates_vol",
              "commodities",
              "semis_sectors",
              "rotation",
              "value_chain_radar",
              "next_session"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30
          },
          "body": {
            "type": "string",
            "minLength": 60,
            "maxLength": 900
          },
          "tickers": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9.\\-]{0,9}$"
            }
          },
          "themes": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "watchpoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 15,
        "maxLength": 200
      }
    },
    "social_summary": {
      "type": "string",
      "minLength": 80,
      "maxLength": 240
    },
    "email_subject": {
      "type": "string",
      "minLength": 10,
      "maxLength": 50
    },
    "email_preview": {
      "type": "string",
      "minLength": 30,
      "maxLength": 120
    },
    "disclaimer": {
      "type": "string",
      "const": "이 글은 시장 구조를 분석한 참고 자료이며 투자 권유가 아닙니다. 투자 판단과 그 결과에 대한 책임은 본인에게 있습니다."
    }
  }
}
